---
title: Databricks + AWS platform (architecture-beta)
config:
  theme: neutral
  look: classic
  architecture:
    randomize: false
---
architecture-beta
  group ops(cloud)[Automation and operators]
  service dev(server)[Developers] in ops
  service pulumi(server)[Pulumi / CI] in ops
  service bundle(server)[Databricks Asset Bundle] in ops

  group aws(disk)[AWS account]
  service s3land(disk)[S3 landing optional] in aws
  service s3ml(disk)[S3 ML artifacts] in aws
  service iam(server)[IAM credentials] in aws

  group dbx(cloud)[Databricks workspace]
  group medallion(database)[Medallion UC layers] in dbx
  service bronze(database)[Bronze raw] in medallion
  service silver(database)[Silver validated] in medallion
  service gold(database)[Gold curated] in medallion

  service jobs(server)[Jobs databricks.yml] in dbx
  service mfexp(database)[MLflow experiment] in dbx
  service mfreg(database)[Model Registry] in dbx
  service sqlw(server)[Serverless SQL WH] in dbx
  service policy(server)[Classic cluster policy] in dbx

  dev:R --> L:pulumi
  dev:R --> L:bundle
  pulumi:B --> T:iam
  iam:R --> L:s3ml
  bundle:B --> T:jobs
  s3land:R --> L:bronze
  jobs:R --> L:bronze
  bronze:R --> L:silver
  silver:R --> L:gold
  jobs:B --> T:mfexp
  mfexp:B --> T:mfreg
  jobs:R --> L:s3ml
  jobs:B --> T:sqlw
  jobs:B --> T:policy
